<footer>
  <span class="footer-logo">楽食事ブログ</span>
  <div class="footer-links">
    <a href="#">プライバシーポリシー</a>
    <a href="#">お問い合わせ</a>
    <a href="/about">このブログについて</a>
  </div>
  <span class="footer-copy">© 2026 楽食事ブログ</span>
</footer>

<style>
  footer {
    border-top: 1px solid var(--line);
    padding: 40px 48px;
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 1rem;
  }
  .footer-logo {
    font-family: var(--serif); font-size: 16px; font-weight: 600;
    letter-spacing: 0.05em; color: var(--text);
  }
  .footer-copy { font-size: 12px; color: var(--text-lite); letter-spacing: 0.04em; }
  .footer-links { display: flex; gap: 28px; }
  .footer-links a {
    font-size: 12px; color: var(--text-lite); text-decoration: none;
    letter-spacing: 0.04em; transition: color .2s;
  }
  .footer-links a:hover { color: var(--text); }
  @media (max-width: 720px) {
    footer { padding: 32px 20px; flex-direction: column; align-items: flex-start; }
  }
</style>
