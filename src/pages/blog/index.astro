---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { client } from '../../lib/microcms';
import type { Blog } from '../../lib/microcms';

const data = await client.getList<Blog>({ endpoint: 'blogs' });
const posts = data.contents;
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`記事一覧 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main { max-width: 960px; margin: 0 auto; padding: 2rem 1rem; }
			ul { display: flex; flex-wrap: wrap; gap: 2rem; list-style: none; margin: 0; padding: 0; }
			ul li { width: calc(50% - 1rem); }
			ul li a { display: block; text-decoration: none; }
			ul li img { width: 100%; border-radius: 12px; margin-bottom: 0.5rem; object-fit: cover; height: 200px; }
			.title { margin: 0; color: #333; font-size: 1.1rem; line-height: 1.4; }
			.date { margin: 0.3rem 0 0; color: #999; font-size: 0.85rem; }
			ul li a:hover .title { color: #e67e22; }
			@media (max-width: 720px) { ul li { width: 100%; } }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>記事一覧</h1>
			{posts.length === 0 && <p>まだ記事がありません。</p>}
			<ul>
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`}>
							{post.eyecatch && (
								<img src={post.eyecatch.url} alt={post.title} />
							)}
							<h4 class="title">{post.title}</h4>
							<p class="date">{new Date(post.publishedAt).toLocaleDateString('ja-JP')}</p>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
