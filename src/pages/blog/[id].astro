---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { client } from '../../lib/microcms';
import type { Blog } from '../../lib/microcms';

// ローカル保存のWordPress完全HTMLを読み込む
const localArticles = import.meta.glob('../../data/articles/*.json', { eager: true }) as Record<string, { default: { content: string } }>;

export async function getStaticPaths() {
  const data = await client.getList<Blog>({ endpoint: 'blogs', queries: { limit: 100 } });
  return data.contents.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props as { post: Blog };

// ローカルJSONがあればそちらの完全HTMLを優先使用
const localKey = Object.keys(localArticles).find(k => k.includes(`/${post.id}.json`));
const content = localKey ? (localArticles[localKey] as any).default.content : post.content;
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title={`${post.title} | ${SITE_TITLE}`} description={post.title} />
    <style>
      main { max-width: 800px; margin: 0 auto; padding: 2rem 1rem; }
      .eyecatch { width: 100%; border-radius: 12px; margin-bottom: 2rem; object-fit: cover; max-height: 400px; }
      .title { font-size: 1.8rem; color: #333; line-height: 1.4; margin-bottom: 0.5rem; }
      .date { color: #999; font-size: 0.85rem; margin-bottom: 2rem; }
      .back { display: inline-block; margin-top: 2rem; color: #e67e22; text-decoration: none; }

      /* ── 記事本文 ── */
      :global(.content) { line-height: 1.9; color: #444; font-size: 1rem; }
      :global(.content p) { margin: 1em 0; }
      :global(.content img) { max-width: 100%; border-radius: 8px; display: block; margin: 1.5em auto; }

      /* 見出し */
      :global(.content h2) {
        font-size: 1.4rem; font-weight: 700;
        margin: 2.5em 0 1em; padding: 0.55em 0.9em;
        background: #fff5ee; border-left: 5px solid #e67e22;
        border-radius: 0 6px 6px 0; color: #333;
      }
      :global(.content h3) {
        font-size: 1.15rem; font-weight: 700;
        margin: 2em 0 0.8em; padding: 0.4em 0 0.4em 0.8em;
        border-left: 3px solid #e67e22; color: #444;
      }
      :global(.content h4) { font-size: 1rem; font-weight: 700; margin: 1.5em 0 0.5em; color: #555; }

      /* リスト */
      :global(.content ul:not(.wp-block-list)) { margin: 1em 0 1em 0.5em; padding: 0; list-style: none; }
      :global(.content ul:not(.wp-block-list) li) { position: relative; padding-left: 1.5em; margin-bottom: 0.5em; }
      :global(.content ul:not(.wp-block-list) li::before) {
        content: "✔"; position: absolute; left: 0;
        color: #e67e22; font-size: 0.85em; top: 0.15em;
      }
      :global(.content .wp-block-list) { margin: 1em 0 1em 1.5em; padding: 0; }
      :global(.content .wp-block-list li) { margin-bottom: 0.5em; }
      :global(.content .wp-block-list.is-style-check_list) { list-style: none; margin-left: 0.5em; padding: 0; }
      :global(.content .wp-block-list.is-style-check_list li) {
        position: relative; padding-left: 1.8em; margin-bottom: 0.5em;
      }
      :global(.content .wp-block-list.is-style-check_list li::before) {
        content: "✅"; position: absolute; left: 0; top: 0.05em;
      }
      :global(.content ol) { margin: 1em 0 1em 1.8em; }
      :global(.content ol li) { margin-bottom: 0.5em; }

      /* 引用・Twitter */
      :global(.content blockquote) {
        margin: 1.5em 0; padding: 1em 1.2em;
        background: #f9f9f9; border-left: 4px solid #ccc;
        border-radius: 4px; color: #555; font-size: 0.95em;
      }
      :global(.content blockquote p) { margin: 0.4em 0; }

      /* テーブル */
      :global(.content table) { width: 100%; border-collapse: collapse; margin: 1.5em 0; font-size: 0.95em; }
      :global(.content th) { background: #e67e22; color: #fff; padding: 0.6em 0.9em; text-align: left; font-weight: 700; }
      :global(.content td) { padding: 0.6em 0.9em; border-bottom: 1px solid #eee; vertical-align: top; }
      :global(.content tr:nth-child(even) td) { background: #fdf8f4; }

      /* リンク・強調 */
      :global(.content a) { color: #e67e22; text-decoration: underline; }
      :global(.content a:hover) { opacity: 0.75; }
      :global(.content strong) { color: #c0392b; font-weight: 700; }

      /* マーカー */
      :global(.swl-marker) { background: linear-gradient(transparent 60%, rgba(255,235,0,0.7) 60%); }
      :global(.mark_yellow) { background: linear-gradient(transparent 60%, rgba(255,235,0,0.7) 60%); }
      :global(.mark_red) { background: linear-gradient(transparent 60%, rgba(255,100,100,0.4) 60%); }
      :global(.mark_green) { background: linear-gradient(transparent 60%, rgba(100,220,100,0.4) 60%); }

      /* ── SWELLボックス ── */
      :global(.wp-block-group.is-style-box_primary) {
        border: 2px solid #e67e22; border-radius: 8px;
        padding: 1.2em 1.4em; margin: 1.5em 0;
      }
      :global(.wp-block-group.is-style-box_success) {
        border: 2px solid #27ae60; border-radius: 8px;
        padding: 1.2em 1.4em; margin: 1.5em 0;
      }
      :global(.wp-block-group.is-style-box_alert) {
        border: 2px solid #e74c3c; border-radius: 8px;
        padding: 1.2em 1.4em; margin: 1.5em 0;
      }
      :global(.wp-block-group.is-style-crease) {
        padding: 1.2em 1.4em; margin: 1em 0;
        border-radius: 6px;
      }
      :global(.has-swl-pale-01-background-color) { background: #fff8f0; }
      :global(.has-swl-pale-02-background-color) { background: #f0fff4; }
      :global(.has-swl-pale-03-background-color) { background: #fff0f0; }
      :global(.wp-block-group__inner-container > p:first-child) { margin-top: 0; }
      :global(.wp-block-group__inner-container > p:last-child) { margin-bottom: 0; }

      /* ── SWELLボタン ── */
      :global(.wp-block-buttons) { display: flex; justify-content: center; margin: 1.5em 0; }
      :global(.wp-block-button a) {
        display: inline-block; padding: 0.7em 2em;
        background: #e67e22; color: #fff; text-decoration: none;
        border-radius: 4px; font-weight: 700; font-size: 1rem;
        transition: opacity 0.2s;
      }
      :global(.wp-block-button a:hover) { opacity: 0.8; color: #fff; }
      :global(.wp-block-button.is-style-btn_solid a) { background: #e67e22; }
      :global(.wp-block-button.is-style-btn_outline a) {
        background: transparent; border: 2px solid #e67e22; color: #e67e22;
      }

      /* ── SWELLふきだし ── */
      :global(.swell-block-balloon) { margin: 1.5em 0; }
      :global(.c-balloon) {
        display: flex; align-items: flex-start; gap: 12px;
      }
      :global(.c-balloon.-bln-right) { flex-direction: row-reverse; }
      :global(.c-balloon__icon) {
        flex-shrink: 0; width: 64px; text-align: center;
      }
      :global(.c-balloon__iconImg) {
        width: 64px !important; height: 64px !important;
        border-radius: 50%; object-fit: cover; display: block;
        margin: 0 auto;
      }
      :global(.c-balloon.-square .c-balloon__iconImg) { border-radius: 8px; }
      :global(.c-balloon__body) {
        position: relative; flex: 1;
        background: #f0f0f0; border-radius: 12px;
        padding: 0.8em 1em;
      }
      :global(.c-balloon.-bln-right .c-balloon__body) { text-align: left; }
      /* 色分け */
      :global(.c-balloon[data-col="blue"] .c-balloon__body) { background: #e8f4fd; }
      :global(.c-balloon[data-col="red"] .c-balloon__body) { background: #fdecea; }
      :global(.c-balloon[data-col="green"] .c-balloon__body) { background: #e8f8e8; }
      :global(.c-balloon[data-col="yellow"] .c-balloon__body) { background: #fffde7; }
      :global(.c-balloon[data-col="pink"] .c-balloon__body) { background: #fce4ec; }
      :global(.c-balloon[data-col="purple"] .c-balloon__body) { background: #f3e5f5; }
      /* 吹き出し三角 */
      :global(.c-balloon__body.-speaking::before) {
        content: ""; position: absolute;
        top: 16px; left: -10px;
        border: 6px solid transparent;
        border-right-color: #f0f0f0;
      }
      :global(.c-balloon[data-col="blue"] .c-balloon__body.-speaking::before) { border-right-color: #e8f4fd; }
      :global(.c-balloon[data-col="red"] .c-balloon__body.-speaking::before) { border-right-color: #fdecea; }
      :global(.c-balloon[data-col="green"] .c-balloon__body.-speaking::before) { border-right-color: #e8f8e8; }
      :global(.c-balloon[data-col="yellow"] .c-balloon__body.-speaking::before) { border-right-color: #fffde7; }
      :global(.c-balloon[data-col="pink"] .c-balloon__body.-speaking::before) { border-right-color: #fce4ec; }
      :global(.c-balloon[data-col="purple"] .c-balloon__body.-speaking::before) { border-right-color: #f3e5f5; }
      :global(.c-balloon.-bln-right .c-balloon__body.-speaking::before) {
        left: auto; right: -10px;
        border-right-color: transparent; border-left-color: #f0f0f0;
      }
      :global(.c-balloon__text) { font-size: 0.95rem; line-height: 1.7; }
      :global(.c-balloon__text p) { margin: 0.3em 0; }
      :global(.c-balloon__shapes) { display: none; }
      :global(.c-balloon__icon span) { display: block; font-size: 0.7rem; color: #888; margin-top: 4px; text-align: center; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      {post.eyecatch && <img class="eyecatch" src={post.eyecatch.url} alt={post.title} />}
      <h1 class="title">{post.title}</h1>
      <p class="date">{new Date(post.publishedAt).toLocaleDateString('ja-JP')}</p>
      <div class="content" set:html={content} />
      <a class="back" href="/blog">← 記事一覧へ戻る</a>
    </main>
    <Footer />
  </body>
</html>
